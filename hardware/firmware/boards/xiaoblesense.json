    "extra_flags": "-DARDUINO_NRF52840_XIAOSENSE -DNRF52840_XXAA -DSEEED_XIAO_NRF52840_SENSE",
    "f_cpu": "64000000L",
    "hwids": [
      ["0x2886", "0x0048"],
      ["0x2886", "0x8048"]
    ],
    "usb_product": "Seeed XIAO nRF52840 Sense",
    "mcu": "nrf52840",
    "variant": "feather_nrf52840_sense",
    "bsp": {
      "name": "adafruit"
    },
    "softdevice": {
      "sd_flags": "-DS140",
